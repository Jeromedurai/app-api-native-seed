@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Reset Your Password";
    ViewData["Preheader"] = "Reset your password securely";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
    var code = V("OTP") ?? V("Code");
}
<p class="h1">Reset your password</p>
<p class="lead">Hi @name, we received a request to reset your password.</p>
@if (!string.IsNullOrWhiteSpace(code)) { <div class="code-box" style="color:@brand">@code</div> <p class="muted center">This code expires shortly. Did not request it? You can ignore this email.</p> }
else { <div class="btn-wrap"><a class="btn" style="background:@brand" href="@site/reset-password">Reset Password</a></div> <p class="muted center">If you did not request this, you can safely ignore this email.</p> }
