@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Back in Stock";
    ViewData["Preheader"] = "Your favourite is available again";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
    var ctaUrl = V("CtaUrl"); var ctaHref = string.IsNullOrWhiteSpace(ctaUrl) ? site : (ctaUrl.StartsWith("/") ? site + ctaUrl : ctaUrl);
}
<p class="h1">@(V("Headline") ?? "🌿 Back in stock")</p>
<p class="lead">@if (!string.IsNullOrWhiteSpace(V("Message"))) { @Html.Raw(V("Message").Replace("\n", "<br>")) } else { <text>Hi @name, an item you were after is available again. Order now before it sells out!</text> }</p>
@if(!string.IsNullOrWhiteSpace(V("ProductName"))){<div class="card-inner"><strong>@V("ProductName")</strong></div>}
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@ctaHref">@(V("CtaText") ?? "Buy Now")</a></div>
