@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Subscription Expired";
    ViewData["Preheader"] = "Your subscription has ended";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
}
<p class="h1">Your subscription has expired</p>
<p class="lead">Hi @name, your subscription has ended. Renew now to keep enjoying your benefits without interruption.</p>
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@site/account">Renew Now</a></div>
