@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Referral Reward";
    ViewData["Preheader"] = "Your reward has arrived";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
}
<p class="h1">🤝 Referral reward unlocked</p>
<p class="lead">Hi @name, thank you for spreading the word! Your referral reward is now available.</p>
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@site/account">Claim Reward</a></div>
