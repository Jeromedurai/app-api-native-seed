@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Password Changed";
    ViewData["Preheader"] = "Your password was changed";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
}
<p class="h1">Your password was changed</p>
<p class="lead">Hi @name, this confirms your account password was successfully updated.</p>
<p class="muted">Did not make this change? <a href="@site/reset-password" style="color:@brand">Reset it now</a> and contact support.</p>
