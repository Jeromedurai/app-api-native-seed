@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Payment Failed";
    ViewData["Preheader"] = "Your payment could not be processed";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
}
<p class="h1">⚠️ Payment failed</p>
<p class="lead">Hi @name, unfortunately we could not process your payment. Please try again to complete your order.</p>
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@site/checkout">Retry Payment</a></div>
