@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Password Reset";
    ViewData["Preheader"] = "Complete your password reset";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
    var code = V("OTP") ?? V("Code");
}
<p class="h1">Reset your password</p>
<p class="lead">Hi @name, use the secure code below to set a new password.</p>
@if (!string.IsNullOrWhiteSpace(code)) { <div class="code-box" style="color:@brand">@code</div> }
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@site/reset-password">Set New Password</a></div>
<p class="muted center">If you did not request this, please contact support immediately.</p>
