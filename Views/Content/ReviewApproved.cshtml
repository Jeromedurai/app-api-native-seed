@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Review Published";
    ViewData["Preheader"] = "Your review is now live";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
}
<p class="h1">✅ Your review is live</p>
<p class="lead">Hi @name, thank you! Your review has been published and is helping fellow gardeners decide.</p>
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@site">See Your Review</a></div>
