@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Happy Birthday";
    ViewData["Preheader"] = "A gift to celebrate your day";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
    var ctaUrl = V("CtaUrl"); var ctaHref = string.IsNullOrWhiteSpace(ctaUrl) ? site : (ctaUrl.StartsWith("/") ? site + ctaUrl : ctaUrl);
}
<p class="h1">🎂 Happy Birthday, @name!</p>
<p class="lead">@if (!string.IsNullOrWhiteSpace(V("Message"))) { @Html.Raw(V("Message").Replace("\n", "<br>")) } else { <text>Wishing you a wonderful day from all of us. Here is a little gift to celebrate — enjoy a special treat on us.</text> }</p>
<div class="code-box" style="color:@brand">@(V("CouponCode") ?? "BDAY20")</div>
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@ctaHref">@(V("CtaText") ?? "Claim Your Gift")</a></div>
