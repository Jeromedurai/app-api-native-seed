@model dynamic
@{
    Layout = "_BrandedEmail";
    ViewData["Title"] = "Renewal Reminder";
    ViewData["Preheader"] = "Your subscription renews soon";
    var d = Model as IDictionary<string, object>;
    string V(string k) => d != null && d.TryGetValue(k, out var x) && x != null ? x.ToString() : null;
    var name = V("Name") ?? V("FirstName") ?? "there"; var brand = V("BrandColor") ?? "#1e7e34"; var site = V("SiteUrl") ?? "#";
}
<p class="h1">Subscription renewal reminder</p>
<p class="lead">Hi @name, your subscription is due to renew soon. No action is needed — we just wanted to keep you informed.</p>
@if(!string.IsNullOrWhiteSpace(V("RenewDate"))){<div class="card-inner"><table class="info-table"><tr><td class="k">Renews On</td><td class="v">@V("RenewDate")</td></tr></table></div>}
<div class="btn-wrap"><a class="btn" style="background:@brand" href="@site/account">Manage Subscription</a></div>
